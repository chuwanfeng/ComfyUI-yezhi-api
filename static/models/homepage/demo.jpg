<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
  <!-- 层叠水墨方块（山石意象） -->
  <rect x="4" y="4" width="7" height="7" rx="1" fill="none" stroke="#1a1a1a" stroke-width="1.3" opacity="0.7"/>
  <rect x="13" y="10" width="7" height="7" rx="1" fill="none" stroke="#6b6660" stroke-width="1" opacity="0.5"/>
  <rect x="8" y="12" width="5" height="5" rx="1" fill="none" stroke="#1a1a1a" stroke-width="1.1" opacity="0.55"/>
  <!-- 淡墨连线 -->
  <path d="M11 8 L14 12" stroke="#c8c0b4" stroke-width="0.7" opacity="0.5"/>
  <path d="M7 12 L10 12" stroke="#c8c0b4" stroke-width="0.7" opacity="0.4"/>
</svg>