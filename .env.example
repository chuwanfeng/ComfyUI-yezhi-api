# ============================================================
# ComfyUI-Yezhi-API 环境变量
# 默认使用 SQLite (开箱即用)。切换 PostgreSQL 时改为 postgresql://...
# ============================================================

# ── 自用模式 ──
# true: 跳过审核/敏感词/限额（完全自用，无限制）
SELF_HOSTED_MODE=true

# ── 核心 ──
SECRET_KEY=change-me-to-a-random-string
DATABASE_URL=sqlite:///./yezhi.db

# ── ComfyUI API 端点 ──
# 至少配置一个，不配置则页面不展示对应模型
HiDream_Fp8_URL=
Flux_Dev_URL=
Flux_Krea_URL=
Kontext_fp8_URL=
Stable_Diffusion_3_5_URL=
Qwen_Image_URL=
Qwen_Image_Edit_URL=
Wai_SDXL_V150_URL=
Wai_SDXL_V170_URL=
Z_IMAGE_URL=
Z_Image_Turbo_URL=
Flux_2_URL=

# ── LLM 提示词优化 ──
PROMPT_OPTIMIZATION_BASE_URL=
PROMPT_OPTIMIZATION_API_KEY=
PROMPT_OPTIMIZATION_MODEL=Qwen/Qwen3-VL-8B-Instruct-FP8
PROMPT_OPTIMIZATION_MAX_TOKENS=2000

# ── 存储 ──
# local: 本地文件系统 (uploads/ 目录)
# oss: 阿里云 OSS
STORAGE_TYPE=local
UPLOAD_DIR=uploads
# 阿里云 OSS (仅 STORAGE_TYPE=oss 时生效)
OSS_AK=
OSS_SK=
OSS_BUCKET=
OSS_ENDPOINT=

# ── 支付宝 (可选) ──
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=

# ── 邮件 (可选, 用于邮箱验证/重置密码) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
